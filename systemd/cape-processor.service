[Unit]
Description=CAPE report processor
Documentation=https://github.com/kevoreilly/CAPEv2
Wants=cape.service
After=cape-rooter.service

[Service]
WorkingDirectory=/opt/CAPEv2/utils/
EnvironmentFile=-/opt/CAPEv2/custom/conf/cape-processor.ini
ExecStart=/etc/poetry/bin/poetry run python process.py -p7 auto -pt {PROCESSING_TIMEOUT:-900}
User=cape
Group=cape
Restart=always
RestartSec=5m
LimitNOFILE=100000

[Install]
WantedBy=multi-user.target
